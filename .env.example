# 去 https://my.telegram.org 用闲置手机号申请，几分钟就好
TG_API_ID=
TG_API_HASH=

# 接收频道的 chat id，形如 -1001234567890；获取方式见 README
RECEIVE_CHAT_ID=
# 私有备份频道的 chat id，两条路径最终都传到这里
ARCHIVE_CHAT_ID=
# 扫描接收频道的间隔，单位秒，默认 5 分钟
SCAN_INTERVAL_SECONDS=300
# 每轮最多处理的消息数，默认 10。账号安全优先，不要随意调高
BATCH_SIZE=10
# 每次上传文件后的冷却时间，单位秒，默认 5。给 Telegram 足够喘息空间
UPLOAD_COOLDOWN_SECONDS=5
